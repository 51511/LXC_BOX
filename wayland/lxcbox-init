#!/bin/sh
# SPDX-License-Identifier: GPL-3.0-only
# lxcbox-init — container-side init, runs as root inside the LXC container
# Replaces: distrobox-init
#
# Responsibilities:
#   1. Detect first-run vs subsequent runs
#   2. First-run: create user, install packages, run hooks
#   3. Every run: keep /etc/{passwd,group,shadow} in sync with host user
#   4. Drop to user shell (or just exit 0 so lxc-start daemonizes cleanly)

set -o errexit
# set -o nounset  # disabled: args may be empty

INIT_DONE_MARKER="/run/.lxcbox-init-done"
SETUP_DONE_MARKER="/.lxcbox-setup-done"

# ── Defaults (overridden by lxc-attach --set-var / lxcbox-create flags) ───────
user_name="${LXCBOX_USER:-root}"
user_uid="${LXCBOX_UID:-1000}"
user_gid="${LXCBOX_GID:-1000}"
user_home="${LXCBOX_HOME:-/home/${user_name}}"
additional_packages="${LXCBOX_PACKAGES:-}"
pre_init_hook="${LXCBOX_PRE_INIT_HOOK:-}"
init_hook="${LXCBOX_INIT_HOOK:-}"
verbose=0
version="0.1.0"

show_help() {
    cat << EOF
lxcbox-init version: ${version}

Run inside the LXC container. Not meant to be called manually.

Options:
    --name:              username to create
    --user:              UID
    --group:             GID
    --home:              home directory path
    --additional-packages: space-separated package list
    --pre-init-hooks:    shell commands before package install
    -- HOOK:             shell commands after setup (init-hooks)
    --verbose/-v:        verbose
    --help/-h:           this message
EOF
}

# ── Argument parsing ──────────────────────────────────────────────────────────
while :; do
    case $1 in
        -h|--help)   show_help; exit 0 ;;
        -v|--verbose) verbose=1; shift ;;
        --name)      [ -n "$2" ] && { user_name="$2";       shift 2; } ;;
        --user)      [ -n "$2" ] && { user_uid="$2";        shift 2; } ;;
        --group)     [ -n "$2" ] && { user_gid="$2";        shift 2; } ;;
        --home)      [ -n "$2" ] && { user_home="$2";       shift 2; } ;;
        --additional-packages) [ -n "$2" ] && { additional_packages="$2"; shift 2; } ;;
        --pre-init-hooks)      [ -n "$2" ] && { pre_init_hook="$2";  shift 2; } ;;
        --) shift; init_hook="$*"; break ;;
        -*) printf >&2 "ERROR: unknown flag '%s'\n" "$1"; exit 1 ;;
        *)  break ;;
    esac
done

[ "${verbose}" -ne 0 ] && set -o xtrace

# ── Helpers ───────────────────────────────────────────────────────────────────
log()  { printf >&2 "[lxcbox-init] %s\n" "$*"; }
die()  { printf >&2 "[lxcbox-init] ERROR: %s\n" "$*"; exit 1; }

# ── Sync user/group into container ───────────────────────────────────────────
# Called on every start (not just first-run) so UID changes on host propagate.
sync_user() {
    log "Syncing user ${user_name} (${user_uid}:${user_gid}) ..."

    # Create group if missing
    if ! getent group "${user_gid}" > /dev/null 2>&1; then
        groupadd -g "${user_gid}" "${user_name}" 2>/dev/null || true
    fi

    # Create or modify user
    if ! getent passwd "${user_uid}" > /dev/null 2>&1; then
        useradd \
            --uid "${user_uid}" \
            --gid "${user_gid}" \
            --home-dir "${user_home}" \
            --no-create-home \
            --shell "$(command -v bash || command -v sh)" \
            "${user_name}" 2>/dev/null || true
    fi

    # Ensure home exists (may be a bind-mounted host path)
    mkdir -p "${user_home}"
    chown "${user_uid}:${user_gid}" "${user_home}" 2>/dev/null || true

    # Allow passwordless sudo inside container (distrobox-style)
    if command -v sudo > /dev/null 2>&1; then
        echo "${user_name} ALL=(ALL) NOPASSWD: ALL" \
            > "/etc/sudoers.d/lxcbox-${user_name}"
        chmod 0440 "/etc/sudoers.d/lxcbox-${user_name}"
    fi
}

# ── First-run setup ───────────────────────────────────────────────────────────
first_run_setup() {
    log "First-run setup for lxcbox ..."

    # -- pre-init hook
    if [ -n "${pre_init_hook}" ]; then
        log "Running pre-init hook ..."
        sh -c "${pre_init_hook}"
    fi

    # -- fix sudo unable to resolve host warning
    if ! grep -q "$(hostname)" /etc/hosts 2>/dev/null; then
        echo "127.0.1.1 $(hostname)" >> /etc/hosts
    fi

    # -- base packages every lxcbox needs
    BASE_PACKAGES="
        bash
        bash-completion
        ca-certificates
        curl
        dbus
        dbus-user-session
        file
        findutils
        gnupg2
        less
        locales
        lsof
        man-db
        procps
        sudo
        tzdata
        util-linux
        wget
        xdg-utils
    "

    # Update package lists
    log "Updating apt ..."
    apt-get update -qq

    # Install base packages
    log "Installing base packages ..."
    # shellcheck disable=SC2086
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        ${BASE_PACKAGES}

    # Install user-requested additional packages
    if [ -n "${additional_packages}" ]; then
        log "Installing additional packages: ${additional_packages} ..."
        # shellcheck disable=SC2086
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            ${additional_packages}
    fi

    # -- Install apt pre-invoke snapshot hook
    install_apt_snapshot_hook

    # -- locale
    if [ -e /etc/locale.gen ]; then
        sed -i 's/^# *en_US.UTF-8/en_US.UTF-8/' /etc/locale.gen
        locale-gen 2>/dev/null || true
    fi

    # -- init hook
    if [ -n "${init_hook}" ]; then
        log "Running init hook ..."
        sh -c "${init_hook}"
    fi

    # Mark setup done
    touch "${SETUP_DONE_MARKER}"
    log "First-run setup complete."
}

# ── apt pre-invoke snapshot hook ─────────────────────────────────────────────
# Installs an apt hook that calls lxcbox-snapshot before every apt operation.
# The hook lives in the container; lxcbox-snapshot on the host side is called
# via lxcbox-host-exec.
install_apt_snapshot_hook() {
    log "Installing apt snapshot hook ..."
    mkdir -p /etc/apt/apt.conf.d

    cat > /etc/apt/apt.conf.d/01lxcbox-snapshot << 'APTHOOK'
// lxcbox — auto-snapshot before apt operations
// Calls lxcbox-snapshot on the host via lxcbox-host-exec
DPkg::Pre-Invoke {
    "if [ -x /usr/bin/lxcbox-host-exec ]; then /usr/bin/lxcbox-host-exec lxcbox-snapshot --auto ${CONTAINER_ID:-} || true; fi";
};
APTHOOK
}

# ── Per-start tasks ────────────────────────────────────────────────────────────
per_start_setup() {
    # Recreate /run/user/<uid> inside container if missing
    # (the host's XDG_RUNTIME_DIR is bind-mounted but we need the dir to exist
    # before the mount happens — lxc-start mounts in order, so this is a no-op
    # in practice, but harmless to ensure)
    mkdir -p "/run/user/${user_uid}"
    chmod 700 "/run/user/${user_uid}"
    chown "${user_uid}:${user_gid}" "/run/user/${user_uid}" 2>/dev/null || true

    # Ensure /run/host exists as a mountpoint
    mkdir -p /run/host

    # Touch the done marker in /run (ephemeral, cleared on each start)
    touch "${INIT_DONE_MARKER}"
}

# ── Main ──────────────────────────────────────────────────────────────────────
# Must be running as root inside the container
if [ "$(id -ru)" -ne 0 ]; then
    die "lxcbox-init must run as root inside the container"
fi

sync_user

if [ ! -e "${SETUP_DONE_MARKER}" ]; then
    first_run_setup
fi

per_start_setup

log "Init complete. Container ready."
# Exit 0 — lxc-start will keep the container running as long as the
# lxc.init.cmd process is alive. We exit here which is correct for
# daemonized start (-d flag in lxcbox-enter). The container stays up
# because LXC holds the namespace open.
exit 0
