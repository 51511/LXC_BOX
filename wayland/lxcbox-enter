#!/bin/sh
# SPDX-License-Identifier: GPL-3.0-only
# lxcbox-enter — attach to a running lxcbox container, or start+attach

[ -z "${USER}" ]  && USER="$(id -run)"
[ -z "${HOME}" ]  && HOME="$(getent passwd "${USER}" | cut -d':' -f6)"
[ -z "${SHELL}" ] && SHELL="$(getent passwd "${USER}" | cut -d':' -f7)"

container_name=""
container_user_uid="$(id -ru)"
container_user_gid="$(id -rg)"
enter_cmd=""
verbose=0
version="0.1.0"

[ "${container_user_uid}" -eq 0 ] && rootful=1 || rootful=0
[ "${rootful}" -eq 1 ] \
    && lxc_dir="/var/lib/lxc" \
    || lxc_dir="${HOME}/.local/share/lxc"

# ── root 執行時警告 ───────────────────────────────────────────────────────────
# lxc-attach 以 root 執行時不會切換 mount namespace，container 會看到 host rootfs
# 應該用一般用戶執行
if [ "${rootful}" -eq 1 ] && [ -n "${SUDO_USER:-}" ]; then
    printf >&2 "WARNING: 請用一般用戶執行 lxcbox-enter，不要用 root/sudo\n"
    printf >&2 "  改用: su - %s -c 'lxcbox enter %s'\n" "${SUDO_USER}" "${container_name}"
fi

sudo_cmd="${DBX_SUDO_PROGRAM:-sudo}"
[ "${rootful}" -eq 1 ] && sudo_cmd=""

show_help() {
    cat << HELPEOF
lxcbox-enter version: ${version}

Usage:
    lxcbox-enter <name>
    lxcbox-enter <name> -- bash
    lxcbox-enter --name mybox

Options:
    --name/-n:    container name
    --root/-r:    use rootful LXC (/var/lib/lxc)
    --verbose/-v: show more output
    --help/-h:    this message
    -- CMD:       command to run instead of default shell
HELPEOF
}

while :; do
    case $1 in
        -h|--help)    show_help; exit 0 ;;
        -v|--verbose) verbose=1; shift ;;
        -r|--root)    rootful=1; lxc_dir="/var/lib/lxc"; sudo_cmd=""; shift ;;
        -n|--name)    [ -n "$2" ] && { container_name="$2"; shift 2; } ;;
        --)           shift; enter_cmd="$*"; break ;;
        -*)           printf >&2 "ERROR: unknown flag '%s'\n" "$1"; show_help; exit 1 ;;
        *)
            if [ -n "$1" ] && [ -z "${container_name}" ]; then
                container_name="$1"; shift
            else
                break
            fi ;;
    esac
done

set -o errexit
set -o nounset
[ "${verbose}" -ne 0 ] && set -o xtrace

if [ -z "${container_name}" ]; then
    printf >&2 "ERROR: no container name specified.\n"
    show_help; exit 1
fi

if [ ! -d "${lxc_dir}/${container_name}" ]; then
    printf >&2 "ERROR: lxcbox '%s' not found in %s\n" "${container_name}" "${lxc_dir}"
    printf >&2 "Create it first:\n  lxcbox-create --name %s\n" "${container_name}"
    exit 1
fi

# ── cgroup ────────────────────────────────────────────────────────────────────
if [ ! -e /sys/fs/cgroup/cgroup.controllers ] && [ ! -e /sys/fs/cgroup/memory ]; then
    printf >&2 "Mounting cgroup2 ...\n"
    mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
fi

# ── XDG_RUNTIME_DIR ───────────────────────────────────────────────────────────
xdg_runtime="/run/user/${container_user_uid}"
if [ ! -d "${xdg_runtime}" ]; then
    mkdir -p "${xdg_runtime}"
    chmod 700 "${xdg_runtime}"
fi

# ── Wayland socket ────────────────────────────────────────────────────────────
# 確保 XDG_RUNTIME_DIR 權限允許 container 存取 Wayland socket
# lxc-attach 會保留 mount namespace，所以 /run/user/<uid> 是共享的
if [ -d "${xdg_runtime}" ]; then
    chmod 755 "${xdg_runtime}" 2>/dev/null || true
fi

# 偵測 Wayland display
wayland_display="${WAYLAND_DISPLAY:-}"
if [ -z "${wayland_display}" ]; then
    # 自動偵測
    for wl in wayland-0 wayland-1; do
        [ -S "${xdg_runtime}/${wl}" ] && { wayland_display="${wl}"; break; }
    done
    wayland_display="${wayland_display:-wayland-0}"
fi

# ── Start container if not running ───────────────────────────────────────────
container_status() {
    ${sudo_cmd} lxc-info -n "${container_name}" -P "${lxc_dir}" 2>/dev/null \
        | grep "^State:" | awk '{print $2}' || echo "STOPPED"
}

state="$(container_status)"

if [ "${state}" != "RUNNING" ]; then
    printf >&2 "Starting lxcbox '%s' ...\n" "${container_name}"
    ${sudo_cmd} lxc-start -n "${container_name}" -P "${lxc_dir}" -d

    i=0
    while [ "${state}" != "RUNNING" ] && [ "${i}" -lt 20 ]; do
        sleep 0.5
        state="$(container_status)"
        i=$((i + 1))
    done

    if [ "${state}" != "RUNNING" ]; then
        printf >&2 "ERROR: container failed to start. Try:\n"
        printf >&2 "  lxc-start -n %s -F\n" "${container_name}"
        exit 1
    fi

    ${sudo_cmd} lxc-attach -n "${container_name}" -P "${lxc_dir}" -- \
        /usr/bin/lxcbox-init \
            --name "${USER}" \
            --user "${container_user_uid}" \
            --group "${container_user_gid}" \
            --home "${HOME}" \
        || true
fi

# ── Forward environment ───────────────────────────────────────────────────────
env_flags=""
env_flags="${env_flags} --set-var TERM=${TERM:-xterm-256color}"
env_flags="${env_flags} --set-var COLORTERM=${COLORTERM:-truecolor}"
env_flags="${env_flags} --set-var HOME=${HOME}"
env_flags="${env_flags} --set-var USER=${USER}"
env_flags="${env_flags} --set-var SHELL=${SHELL}"
env_flags="${env_flags} --set-var CONTAINER_ID=${container_name}"
env_flags="${env_flags} --set-var XDG_RUNTIME_DIR=${xdg_runtime}"
env_flags="${env_flags} --set-var WAYLAND_DISPLAY=${wayland_display}"
env_flags="${env_flags} --set-var DBUS_SESSION_BUS_ADDRESS=unix:path=${xdg_runtime}/bus"
env_flags="${env_flags} --set-var TERMINFO_DIRS=/usr/share/terminfo:/run/host/usr/share/terminfo"
env_flags="${env_flags} --set-var DISPLAY=${DISPLAY:-:0}"
env_flags="${env_flags} --set-var XAUTHORITY=${HOME}/.Xauthority"
env_flags="${env_flags} --set-var LANG=zh_TW.UTF-8"
env_flags="${env_flags} --set-var LC_ALL=zh_TW.UTF-8"
env_flags="${env_flags} --set-var LOCPATH=/usr/lib/locale"

# ── Attach ────────────────────────────────────────────────────────────────────
if [ -z "${enter_cmd}" ]; then
    exec ${sudo_cmd} lxc-attach \
        -n "${container_name}" -P "${lxc_dir}" \
        --uid "${container_user_uid}" \
        --gid "${container_user_gid}" \
        ${env_flags} \
        -- "${SHELL}" -l
else
    exec ${sudo_cmd} lxc-attach \
        -n "${container_name}" -P "${lxc_dir}" \
        --uid "${container_user_uid}" \
        --gid "${container_user_gid}" \
        ${env_flags} \
        -- ${enter_cmd}
fi
